{
  "budget": 40000,
  "ignorePaths": [
    "node_modules",
    "dist",
    ".git",
    "*.vsix",
    "coverage",
    ".next",
    "build",
    "*.lock",
    "*.log"
  ],
  "pinnedFiles": [
    "packages/shared/src/types.ts",
    "PROJECT_RULES.md",
    "pnpm-workspace.yaml"
  ],
  "fileTypePriorities": {
    "index.ts": 1.0,
    "index.tsx": 1.0,
    "types.ts": 0.95,
    "*.config.ts": 0.7,
    "*.test.ts": 0.2,
    "*.spec.ts": 0.2,
    "*.md": 0.3
  },
  "scoringWeights": {
    "centrality": 0.40,
    "recency": 0.25,
    "fileType": 0.20,
    "pin": 0.15
  }
}
