{
    "name": "@context-pilot-v1/cli",
    "version": "0.2.1",
    "description": "Context Pilot CLI — AI context management for your codebase",
    "bin": {
        "context-pilot": "./dist/index.js"
    },
    "main": "./dist/index.js",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "require": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup src/index.ts --format cjs --dts --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/"
    },
    "dependencies": {
        "@context-pilot-v1/core": "workspace:*",
        "chalk": "^5.6.2",
        "chokidar": "^4.0.3",
        "commander": "^14.0.3",
        "ora": "^9.3.0"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "tsup": "^8.0.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "publishConfig": {
        "access": "public"
    }
}
